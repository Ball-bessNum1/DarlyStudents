&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	ЗаполнитьРасписаниеНаСервере();
	ОповеститьОбИзменении(ПараметрКоманды);
КонецПроцедуры   

&НаСервере
Функция НайтиДокументЗаДень(ИскомаяДата)
	// Ищем любой не помеченный на удаление документ в пределах переданного дня
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Расписание.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.Расписание КАК Расписание
		|ГДЕ
		|	Расписание.Дата МЕЖДУ &НачалоДня И &КонецДня
		|	И Расписание.ПометкаУдаления = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("НачалоДня", НачалоДня(ИскомаяДата));
	Запрос.УстановитьПараметр("КонецДня", КонецДня(ИскомаяДата));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		Возврат Выборка.Ссылка; // Возвращаем найденный документ
	Иначе
		Возврат Документы.Расписание.ПустаяСсылка(); // Ничего не нашли
	КонецЕсли;
КонецФункции

&НаСервере
Процедура ЗаполнитьРасписаниеНаСервере()
	НачалоЭтойНедели = НачалоНедели(ТекущаяДатаСеанса()); 
	
	Для КоличествоДобавленныхДней = 0 по 13 Цикл
		ДатаСтарого = НачалоЭтойНедели + 60 * 60 * 24 * КоличествоДобавленныхДней;
		Если ДеньНедели(ДатаСтарого) = 7 Тогда
			Продолжить;
		КонецЕсли;
		// ИСПОЛЬЗУЕМ НОВЫЙ ПОИСК ПО ДАТЕ:
		СтарыйДокумент = НайтиДокументЗаДень(ДатаСтарого);
		
		Если СтарыйДокумент.Пустая() Тогда
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Исходный документ не найден от " + Формат(ДатаСтарого, "ДФ='д ММММ гггг, дддд'");
			Сообщение.Сообщить();  
			Продолжить;
		КонецЕсли;
		
		ДатаНового = ДатаСтарого + 60 * 60 * 24 * 14; 
		
		// ПРОВЕРЯЕМ СУЩЕСТВОВАНИЕ НОВОГО ТОЖЕ ПО ДАТЕ:
		Если НайтиДокументЗаДень(ДатаНового).Пустая() Тогда
			НовыйДокумент = Документы.Расписание.СоздатьДокумент();
			
			// Ставим время на начало дня, чтобы было аккуратно (00:00:00)
			НовыйДокумент.Дата = НачалоДня(ДатаНового); 
			
			// СТРОКУ С ПРИСВОЕНИЕМ НОМЕРА МЫ УДАЛИЛИ.
			// Платформа 1С сама присвоит правильный номер (00000002, 00000003 и т.д.) при записи.
			
			Для Каждого СтрокаСтарого Из СтарыйДокумент.РасписаниеВТаблице Цикл
				НоваяСтрока = НовыйДокумент.РасписаниеВТаблице.Добавить();
				НоваяСтрока.Предмет = СтрокаСтарого.Предмет;
			КонецЦикла;
			
			НовыйДокумент.Записать();
		Иначе
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Расписание уже существует на " + Формат(ДатаНового, "ДФ='д ММММ гггг, дддд'");
			Сообщение.Сообщить();
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры